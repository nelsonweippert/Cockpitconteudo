# Copie pra .env.local e preencha

# ── Database ───────────────────────────────────────────────────────────
# Postgres (Prisma Data Platform ou qualquer Postgres)
DATABASE_URL="postgres://user:pass@host:5432/dbname?sslmode=require"

# ── Auth (NextAuth 5) ──────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="GERAR_COM_openssl_rand_base64_32"
AUTH_SECRET="GERAR_COM_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3020"   # em prod, troca pra URL real

# ── Anthropic (Claude) ─────────────────────────────────────────────────
# Pro pipeline de ideias + curadoria de fontes
ANTHROPIC_API_KEY=""

# ── Telegram Bot (digest diário) ───────────────────────────────────────
# Criar via @BotFather no Telegram, ele retorna o token.
TELEGRAM_BOT_TOKEN=""

# ── Migração (opcional) ────────────────────────────────────────────────
# Só preenche se for rodar scripts/migrate-from-cockpit.ts
OLD_DATABASE_URL=""

# ── Overrides de modelo (opcional) ─────────────────────────────────────
# Defaults: Haiku pra discovery/triage/deep, Sonnet pra narrative
# DISCOVERY_MODEL="claude-haiku-4-5"
# TRIAGE_MODEL="claude-haiku-4-5"
# DEEP_MODEL="claude-haiku-4-5"
# NARRATIVE_MODEL="claude-sonnet-4-6"
