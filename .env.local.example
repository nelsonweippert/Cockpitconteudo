# Copie pra .env.local e preencha

# ── Database ───────────────────────────────────────────────────────────
# Postgres (Prisma Data Platform ou qualquer Postgres)
DATABASE_URL="postgres://user:pass@host:5432/dbname?sslmode=require"

# ── Auth (NextAuth 5) ──────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET="GERAR_COM_openssl_rand_base64_32"
AUTH_SECRET="GERAR_COM_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3020"   # em prod, troca pra URL real

# ── Anthropic (Claude) ─────────────────────────────────────────────────
# Pro pipeline de ideias + curadoria de fontes
ANTHROPIC_API_KEY=""

# ── Telegram Bot (digest diário + Coach via webhook) ──────────────────
# Criar via @BotFather no Telegram, ele retorna o token.
TELEGRAM_BOT_TOKEN=""

# Secret pra validar requests do webhook do Telegram (header
# X-Telegram-Bot-Api-Secret-Token). Gera com: openssl rand -base64 32
TELEGRAM_WEBHOOK_SECRET=""

# ── Cron (Vercel Cron Jobs) ────────────────────────────────────────────
# Proteção do endpoint /api/cron/daily-report. Gera com: openssl rand -base64 32
# A Vercel envia automaticamente o header Authorization: Bearer ${CRON_SECRET}
# quando roda os crons em prod. Precisa configurar a mesma string na Vercel.
CRON_SECRET=""

# ── Google OAuth (YouTube Data + Analytics) ──────────────────────────
# Setup: console.cloud.google.com → APIs & Services → Credentials
# 1. Criar OAuth Client ID (Web application)
# 2. Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/youtube/callback
# 3. Habilitar APIs: YouTube Data API v3 + YouTube Analytics API
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── YouTube Data API key (Keyword Explorer) ─────────────────────────
# API key separada (não-OAuth) pra search público — usada no /keyword pra
# trazer top vídeos competindo. Mesmo projeto Google Cloud, mas API Key
# (não OAuth Client). Restrinja por API/IP em prod.
YOUTUBE_API_KEY=""

# ── Migração (opcional) ────────────────────────────────────────────────
# Só preenche se for rodar scripts/migrate-from-cockpit.ts
OLD_DATABASE_URL=""

# ── Overrides de modelo (opcional) ─────────────────────────────────────
# Defaults: Haiku pra discovery/triage/deep, Sonnet pra narrative
# DISCOVERY_MODEL="claude-haiku-4-5"
# TRIAGE_MODEL="claude-haiku-4-5"
# DEEP_MODEL="claude-haiku-4-5"
# NARRATIVE_MODEL="claude-sonnet-4-6"
